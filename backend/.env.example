APP_NAME=LearnAble API
APP_ENV=dev

# Required: must be at least 32 characters. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-this-with-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Required: Docker Compose maps Postgres to port 5433
DATABASE_URL=postgresql+psycopg://learnable:learnable@localhost:5433/learnable

# Optional: leave empty to use built-in fallback AI responses
GEMINI_API_KEY=

TOTP_ISSUER=LearnAble

LOCKOUT_MAX_ATTEMPTS=10
LOCKOUT_MINUTES=15

# Frontend runs on port 3001 (vite.config.ts). Add 5173 if using default Vite port.
CORS_ORIGINS=http://localhost:3001,http://localhost:5173,http://127.0.0.1:5173

# Required: generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=replace-with-output-of-above-command

# Set to true in production to require a valid JWT to join a call room
REQUIRE_CALL_AUTH=true
