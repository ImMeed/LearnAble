APP_NAME=LearnAble API
APP_ENV=dev

# Required: must be at least 32 characters. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-this-with-a-random-secret-at-least-32-chars

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Required: Docker Compose maps Postgres to port 5433
DATABASE_URL=postgresql+psycopg://learnable:learnable@localhost:5433/learnable

# Optional: leave empty to use built-in fallback AI responses
GEMINI_API_KEY=




APP_NAME=LearnAble API
APP_ENV=dev   # dev | production


DATABASE_URL=postgresql+psycopg://learnable:learnable@localhost:5433/learnable


# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60


TOTP_ISSUER=LearnAble


LOCKOUT_MAX_ATTEMPTS=10
LOCKOUT_MINUTES=15


CORS_ORIGINS=http://localhost:5173


GEMINI_API_KEY=
