VITE_API_BASE_URL=http://localhost:8000

# ICE servers for WebRTC. Without a TURN server, calls will fail if both peers
# are behind restrictive NAT (common in schools/corporate networks).
#
# For production, run your own Coturn server or use a paid TURN provider
# (e.g. Metered, Twilio, Xirsys) and replace the entry below.
#
# The value must be valid JSON (array of RTCIceServer objects).
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"stun:stun1.l.google.com:19302"},{"urls":"turn:openrelay.metered.ca:80","username":"openrelayproject","credential":"openrelayproject"},{"urls":"turn:openrelay.metered.ca:443","username":"openrelayproject","credential":"openrelayproject"}]
