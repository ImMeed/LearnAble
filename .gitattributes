# Normalize all text files to LF in the repo
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.env text eol=lf
*.example text eol=lf

# Binary files — never convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
